---
import { siteConfig } from '../config';

const points = [
  {
    label: 'Lightweight',
    desc: 'Just experiments and a clean dashboard',
  },
  {
    label: 'No huge SaaS bills',
    desc: 'Pay $5/mo for small server, not $5,000/mo for Amplitude',
  },
  {
    label: 'No credit cards',
    desc: 'Just try the demo. No credit card needed',
  },
  {
    label: 'Minutes to set up',
    desc: 'One Docker container. Your data never leaves your server',
  },
];
---

<section
  class="relative flex items-center justify-center px-5 py-12 sm:px-6 sm:py-20"
>
  <div class="relative mx-auto max-w-4xl text-center">
    <h1
      class="text-balance text-4xl font-semibold leading-[1.08] tracking-tight text-ink-900 sm:text-6xl sm:leading-[1.05] md:text-7xl"
    >
      A/B testing that runs on a
      <span
        class="whitespace-nowrap underline decoration-brand-500 decoration-[3px] underline-offset-[8px] sm:decoration-[4px] sm:underline-offset-[12px] md:underline-offset-[14px]"
        >$5 VPS</span
      >
    </h1>

    <ul
      class="mx-auto mt-10 grid max-w-2xl gap-x-8 gap-y-4 text-left sm:mt-14 sm:gap-x-10 sm:gap-y-5 sm:grid-cols-2"
    >
      {
        points.map((p) => (
          <li class="flex items-start gap-3">
            <span class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand-50 text-brand-600">
              <svg
                viewBox="0 0 20 20"
                fill="currentColor"
                class="h-3.5 w-3.5"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 0 1 1.4-1.4l3.8 3.8 6.8-6.8a1 1 0 0 1 1.4 0Z"
                  clip-rule="evenodd"
                />
              </svg>
            </span>
            <div class="min-w-0">
              <p class="text-base font-semibold text-ink-900 sm:text-lg">
                {p.label}
              </p>
              <p class="mt-0.5 text-sm text-ink-500 sm:text-base">{p.desc}</p>
            </div>
          </li>
        ))
      }
    </ul>

    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:mt-12 sm:flex-row sm:gap-4">
      <a
        href={siteConfig.adminUrl}
        class="group inline-flex h-14 w-full items-center justify-center gap-2 rounded-xl bg-ink-900 px-8 text-lg font-medium text-white shadow-sm transition hover:bg-ink-800 sm:w-auto"
      >
        Try a demo
        <svg
          class="h-5 w-5 transition group-hover:translate-x-0.5"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
      <a
        href={siteConfig.githubUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex h-14 w-full items-center justify-center gap-2 rounded-xl border border-ink-200 bg-white px-8 text-lg font-medium text-ink-800 transition hover:border-ink-300 hover:bg-ink-50 sm:w-auto"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1.18-.02-2.14-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.71 0-1.26.45-2.3 1.19-3.11-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.18 1.19a11 11 0 0 1 5.79 0c2.2-1.5 3.17-1.19 3.17-1.19.62 1.59.23 2.77.11 3.06.74.81 1.19 1.85 1.19 3.11 0 4.44-2.69 5.41-5.25 5.7.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.68.8.56C20.22 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z" />
        </svg>
        View on GitHub
      </a>
    </div>

    <p class="mt-8 text-balance text-sm text-ink-600 sm:text-base md:text-lg">
      Yes, this demo runs on a
      <span class="font-semibold text-ink-900">$5 server</span>. And it runs
      well.
    </p>
  </div>
</section>
