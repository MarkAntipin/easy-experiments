# --- Required ---

# Secret used to sign admin JWTs. Use a long, random string.
JWT_SECRET=replace-with-a-long-random-string

# --- Auth (pick one) ---

# Google sign-in:
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# email + password:
# A company + admin user is seeded on first startup if the users table is empty.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-please

# --- Common ---

APPLICATION_PORT=18200
DATABASE_URL=sqlite://easy-experiments.db
DUCKDB_PATH=easy-experiments.duckdb

# `json` for structured logs, unset for dev logs.
LOG_FORMAT=json

# Public URL where the admin UI is served. Used to render accept-invite links.
# APP_BASE_URL=http://localhost:18200

# Comma-separated origins allowed by CORS. Unset = same-origin only.
# CORS_ALLOWED_ORIGINS=http://localhost:5173
