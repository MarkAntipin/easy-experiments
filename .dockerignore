# Build artifacts
target/
**/*.rs.bk
**/*.rlib

# VCS / IDE
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# OS / temp
*.log
*.tmp
*.DS_Store
*.bak
*.~*

# Docker
.dockerignore
Dockerfile
docs/

# Secrets — never bake into the image
.env
.env.*

# Local databases — must come from the volume at runtime, not the image
*.db
*.db-wal
*.db-shm
*.duckdb
*.duckdb.wal

# Not needed by the Rust build
tests/
branding/

# UI: source files are needed by the ui-builder stage, but its own build
# artifacts and dependencies must not be sent in the context (the stage
# installs deps and builds fresh inside the image).
ui/node_modules/
ui/dist/
