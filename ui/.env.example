# API base URL. Leave empty to use the Vite dev proxy (recommended in dev).
# In production, set to your backend origin e.g. https://api.example.com
VITE_API_BASE_URL=

# Target the Vite dev proxy forwards /admin and /api to.
VITE_API_PROXY_TARGET=http://127.0.0.1:18200

# Google OAuth client id (must match backend GOOGLE_CLIENT_ID).
VITE_GOOGLE_CLIENT_ID=
